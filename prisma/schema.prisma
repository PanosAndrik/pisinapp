// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TECHNICIAN
}

enum PoolType {
  INDOOR
  OUTDOOR
}

model Company {
  id               String            @id @default(cuid())
  name             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  users            User[]
  pools            Pool[]
  maintenanceRules MaintenanceRule[]
  visits           Visit[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String
  passwordHash String?
  role         UserRole @default(TECHNICIAN)
  isActive     Boolean  @default(true)
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  visits       Visit[]  @relation("TechnicianVisits")

  @@index([companyId])
}

model Pool {
  id           String            @id @default(cuid())
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code         String
  clientName   String
  address      String?
  volumeLiters Int?
  poolType     PoolType?
  notes        String?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  visits       Visit[]
  rules        MaintenanceRule[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Visit {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  poolId          String
  pool            Pool         @relation(fields: [poolId], references: [id], onDelete: Cascade)
  technicianId    String?
  technician      User?        @relation("TechnicianVisits", fields: [technicianId], references: [id], onDelete: SetNull)
  performedAt     DateTime
  ph              Decimal?     @db.Decimal(4, 2)
  chlorinePpm     Decimal?     @db.Decimal(5, 2) // free chlorine
  totalChlorinePpm Decimal?    @db.Decimal(5, 2)
  hardnessPpm     Decimal?     @db.Decimal(6, 2)
  alkalinityPpm   Decimal?     @db.Decimal(6, 2)
  oxygenConcentrationPpm Decimal? @db.Decimal(6, 2)
  cyanuricAcidPpm Decimal?     @db.Decimal(6, 2)
  ironPpm         Decimal?     @db.Decimal(6, 2)
  microbeTest     String?
  waterClarityOk  Boolean?
  saltPpm         Decimal?     @db.Decimal(7, 2)
  temperatureC    Decimal?     @db.Decimal(4, 1)
  pressureBar     Decimal?     @db.Decimal(4, 2)
  pressureBarSecondary Decimal? @db.Decimal(4, 2)
  cleaningChecks  Json?
  electricalChecks Json?
  chemicalAdditions Json?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  photos          VisitPhoto[]

  @@index([companyId])
  @@index([poolId, performedAt])
}

model VisitPhoto {
  id        String   @id @default(cuid())
  visitId   String
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  imageUrl  String
  caption   String?
  createdAt DateTime @default(now())

  @@index([visitId])
}

model MaintenanceRule {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  poolId          String?
  pool            Pool?     @relation(fields: [poolId], references: [id], onDelete: Cascade)
  title           String
  actionCode      String
  intervalDays    Int
  lastCompletedAt DateTime?
  nextDueAt       DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId, isActive])
  @@index([poolId])
}
